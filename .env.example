# === FUENTES DE DATOS ===
AEMET_API_KEY=                          # AEMET OpenData JWT (obligatorio)

# === RAIF (Red de Alerta e Información Fitosanitaria de Andalucía) ===
RAIF_API_KEY=                           # Token de acceso RAIF MCP (obligatorio para alertas fitosanitarias)
RAIF_BASE_URL=https://raif-gamma.vercel.app  # Endpoint base RAIF (opcional)
AEMET_OBSERVATION_URL=                  # Override endpoint (opcional)
AEMET_TIMEOUT_MS=4000                   # Timeout petición AEMET
AEMET_MAX_ATTEMPTS=2                    # Reintentos AEMET
AEMET_RETRY_DELAY_MS=350                # Delay entre reintentos
AEMET_CACHE_MAX_AGE_MINUTES=240         # Max edad caché AEMET (4h)
AEMET_REFRESH_INTERVAL_MS=900000        # Intervalo refresco (15 min)
AEMET_FAILURE_COOLDOWN_MS=600000        # Cooldown tras fallo (10 min)
AEMET_RATE_LIMIT_COOLDOWN_MS=900000     # Cooldown tras 429 (15 min)

# === SATELITE ===
SENTINEL_HUB_CLIENT_ID=                 # Copernicus Data Space
SENTINEL_HUB_CLIENT_SECRET=

# === BASES DE DATOS ===
DATABASE_URL=                           # Neon PostgreSQL (obligatorio)
NEON_DATABASE_URL=                      # Alternativa
STATIONS_DATABASE_URL=                  # BD estaciones TecRural (opcional)

# === ADMINISTRACION ===
CRON_SECRET=                            # Protección endpoints cron
ADMIN_PASSWORD=                         # Acceso /admin
ADMIN_SESSION_SECRET=                   # Firma cookies admin
